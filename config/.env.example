# Royal Shield Backend - Environment Configuration
# Copy this file to .env and fill in your API credentials

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL with PostGIS extension
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=royal_shield_risk_db
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# =============================================================================
# CRIME DATA SOURCES
# =============================================================================
# FBI Crime Data API
# Register at: https://api.data.gov/signup/
FBI_CRIME_API_KEY=YOUR_FBI_API_KEY

# Miami-Dade Open Data Portal (Socrata)
# Register at: https://opendata.miamidade.gov/profile/app_tokens
MIAMI_DADE_APP_TOKEN=YOUR_SOCRATA_APP_TOKEN

# =============================================================================
# ENVIRONMENTAL DATA SOURCES
# =============================================================================
# NASA FIRMS (Fire Detection)
# Register at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=YOUR_NASA_FIRMS_KEY

# NOAA Climate Data
# Register at: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_TOKEN=YOUR_NOAA_TOKEN

# =============================================================================
# OSINT FEEDS
# =============================================================================
# Reddit API
# Register at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=RoyalShield/1.0

# News API
# Register at: https://newsapi.org/register
NEWS_API_KEY=YOUR_NEWS_API_KEY

# Twitter API (Optional - expensive)
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN
TWITTER_API_KEY=YOUR_TWITTER_API_KEY
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET

# =============================================================================
# VECTOR DATABASE
# =============================================================================
# Pinecone (Recommended)
# Register at: https://app.pinecone.io/
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=royal-shield-zones

# Alternative: Weaviate
# WEAVIATE_URL=YOUR_WEAVIATE_URL
# WEAVIATE_API_KEY=YOUR_WEAVIATE_KEY

# Alternative: Qdrant
# QDRANT_URL=YOUR_QDRANT_URL
# QDRANT_API_KEY=YOUR_QDRANT_KEY

# =============================================================================
# EMBEDDING & AI SERVICES
# =============================================================================
# OpenAI API (Optional - for embeddings & NLP)
# Register at: https://platform.openai.com/signup
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Alternative: Use local Sentence-BERT (free, no API needed)
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# GOOGLE CLOUD PLATFORM (Optional - for deployment)
# =============================================================================
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# =============================================================================
# API SECURITY
# =============================================================================
# JWT Secret for API authentication
JWT_SECRET=YOUR_RANDOM_SECRET_KEY_CHANGE_THIS_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/royal_shield_backend.log

# Data Collection Schedule
DATA_COLLECTION_INTERVAL_HOURS=6

# ML Model Retraining Schedule
MODEL_RETRAIN_INTERVAL_DAYS=7

# Cache Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# =============================================================================
# MIAMI-DADE SPECIFIC CONFIGURATION
# =============================================================================
# Bounding box for data collection (Miami-Dade County)
BBOX_MIN_LAT=25.1398
BBOX_MIN_LNG=-80.8738
BBOX_MAX_LAT=25.9740
BBOX_MAX_LNG=-80.1194

# Default H3 resolution for risk zones
DEFAULT_H3_RESOLUTION=9

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_CRIME_COLLECTION=true
ENABLE_ENVIRONMENTAL_COLLECTION=true
ENABLE_OSINT_COLLECTION=true
ENABLE_CAMERA_INTEGRATION=false
ENABLE_ML_PREDICTIONS=true
ENABLE_VECTOR_SEARCH=true
